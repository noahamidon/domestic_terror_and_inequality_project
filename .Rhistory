wiid <- read.csv(file.choose())
gtd %>% glimpse()
library(tidyverse)
library(readxl)
terror <- gtd %>%
filter(INT_LOG == 0) %>%
select(c("iyear", "country_txt", "nkill", "region")) %>%
group_by(country_txt, iyear) %>%
summarize(tot_events = n(),
tot_deaths = sum(nkill),
.groups = "drop")
wiid %>% glimpse()
ginis <- wiid %>%
select(c("year", "country", "gini")) %>%
group_by(year, country) %>%
summarize(gini = mean(gini, na.rm = TRUE),
.groups = "drop")
final2 <- terror %>%
left_join(ginis, by = c(
"iyear" = "year",
"country_txt" = "country"
)) %>%
drop_na()
